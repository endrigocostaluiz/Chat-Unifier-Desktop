{
  "name": "chat-unifier",
  "version": "1.2.1",
  "description": "Unificador de chats para Streamers (Twitch/YT/Kick) via Scraping Local",
  "main": "main.js",
  "author": "Endrigo",
  "scripts": {
    "start": "electron .",
    "build": "react-scripts build",
    "electron-build": "electron-builder",
    "dev": "concurrently \"npm run start\" \"react-scripts start\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "lucide-react": "^0.284.0",
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "electron": "^26.2.1",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.1"
  },
  "build": {
    "appId": "com.driftweb.chatunifier",
    "productName": "Chat Unifier",
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    }
  }
}